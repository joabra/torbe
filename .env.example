# Kopiera den här filen till .env.local och fyll i dina egna värden.

# NextAuth
AUTH_SECRET=din_hemlighet_här

# Databas (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/torbe

# Kiwi Tequila API – hämta din nyckel på https://tequila.kiwi.com
KIWI_API_KEY=din_nyckel_här

# E-post (valfritt)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=lösenord
# SMTP_FROM=noreply@example.com
# ADMIN_EMAIL=admin@example.com
