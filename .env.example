# Kopiera den här filen till .env.local och fyll i dina egna värden.

# NextAuth
AUTH_SECRET=din_hemlighet_här

# Databas (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/torbe

# Vercel Blob – bildlagring (lägg till via Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=din_blob_token_här

# Travelpayouts / Aviasales – flyg­priser (Ryanair, Norwegian, SAS m.fl.)
# Skapa ett gratis konto på https://travelpayouts.com för att få en token
TRAVELPAYOUTS_TOKEN=din_token_här

# Amadeus Self-Service API – skapa ett gratis konto på https://developers.amadeus.com
AMADEUS_API_KEY=din_api_key_här
AMADEUS_API_SECRET=din_api_secret_här
# Valfritt: byt till test-miljön med https://test.api.amadeus.com
# AMADEUS_BASE_URL=https://api.amadeus.com

# E-post (valfritt)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=lösenord
# SMTP_FROM=noreply@example.com
# ADMIN_EMAIL=admin@example.com
